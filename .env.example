# ── Real values go in Vercel env vars (NOT committed). This file is names only. ──

# Jobber app (OAuth)
JOBBER_CLIENT_ID=
JOBBER_CLIENT_SECRET=
# Public callback URL registered in the Jobber app
JOBBER_REDIRECT_URI=https://YOUR_DOMAIN/jobber/oauth/callback
# Captured ONCE from /jobber/oauth/callback after AOB authorizes (rotation off → stays valid)
JOBBER_REFRESH_TOKEN=

# Meta Lead Ads
META_PAGE_TOKEN=
META_GRAPH_VERSION=v21.0
# Webhook verify token (Meta handshake) — overrides the hardcoded default in /leads/meta
META_VERIFY_TOKEN=d942ce33aca980c8a005d1350aad88f4

# Existing site SMS (already in use)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
MY_PHONE_NUMBER=
